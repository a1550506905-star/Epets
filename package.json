{
  "name": "deskpet",
  "version": "0.5.13",
  "description": "Windows桌面宠物",
  "main": "main.js",
  "scripts": {
    "start": "node run.js",
    "dev": "node run.js",
    "build": "electron-builder --win"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.17",
    "pdfjs-dist": "^3.11.174"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.deskpet.app",
    "productName": "桌面宠物",
    "directories": { "output": "dist" },
    "extraResources": [
      { "from": "pets", "to": "pets" },
      { "from": "图标.png", "to": "图标.png" },
      { "from": "暂存文件", "to": "暂存文件" }
    ],
    "files": [
      "main.js",
      "preload.js",
      "run.js",
      "src/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "图标.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
